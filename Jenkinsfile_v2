pipeline {
    agent any
    tools {
        maven 'maven' 
    }
    stages {
        stage('Test') {
            steps {
                sh 'mvn test'
            }
        }
        stage('Build') {
            steps {
                sh 'mvn clean package'
            }
        }
        stage('Containerize & Deploy') {
            steps {
                // Here we use the gcloud tools to push to the registry
                script {
                    withCredentials([
                        file(credentialsId: 'service_account', variable: 'KEY'),
                        string(credentialsId: 'project_id', variable: 'PROJECT'),
                        string(credentialsId: 'repo_path', variable: 'REPO'),
                        string(credentialsId: 'cluster_name', variable: 'CLUSTER'),
                        string(credentialsId: 'cluster_zone', variable: 'ZONE')
                    ]) {
                        sh 'gcloud auth activate-service-account --key-file=$KEY'
                        sh 'gcloud config set project $PROJECT'
                        
                        // Build and Push
                        sh 'docker build -t $REPO:latest .'
                        sh 'docker push $REPO:latest'
                        
                        // Deploy
                        sh 'gcloud container clusters get-credentials $CLUSTER --zone $ZONE'
                        sh 'kubectl apply -f binarycalculator-deploy.yaml'
                        sh 'kubectl apply -f binarycalculator-service.yaml'
                    }
                }
            }
        }
    }
}
